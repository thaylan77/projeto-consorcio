# =============================================================================
# .env.example — copie este arquivo para .env e preencha os valores
# Nunca versione o .env real (adicione ao .gitignore)
# =============================================================================

# ---------------------------------------------------------------------------
# OBRIGATORIO — sistema nao inicia sem estes valores
# ---------------------------------------------------------------------------

# Token Bearer da API MicroWork (extrator de boletos)
BEARER_TOKEN_MICROWORK=

# Credenciais do portal CNY (buscador Selenium)
CNY_USUARIO=
CNY_SENHA=

# Token da API Sunchat (envio de WhatsApp)
TOKEN_SUNCHAT=

# Chave secreta do Dashboard (protege POST /api/run e similares)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# ---------------------------------------------------------------------------
# SEGURANCA — webhook Sunchat
# ---------------------------------------------------------------------------

# Segredo compartilhado para autenticar POSTs em /webhook/sunchat
# Configure o mesmo valor no painel Sunchat > Webhook > Secret Header
# Se vazio, o webhook aceita qualquer requisicao (nao recomendado em producao)
SUNCHAT_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# PASTAS DE BOLETOS
# ---------------------------------------------------------------------------

# Pasta raiz onde serao criadas as subpastas Para_Enviar, Validados, etc.
PASTA_BASE=C:\Boletos

# ---------------------------------------------------------------------------
# LOG
# ---------------------------------------------------------------------------

# Caminho do arquivo de log (padrao: app.log na pasta do projeto)
# LOG_FILE=C:\ti\Projeto Consorcio\app.log
LOG_MAX_MB=10
LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# REGRAS DE NEGOCIO
# ---------------------------------------------------------------------------

# Valor minimo de emissao de boleto para processar (R$)
VALOR_MINIMO_EMISSAO=15.00

# Quantos meses retroativos buscar na API MicroWork
MESES_RETROATIVOS=9

# ---------------------------------------------------------------------------
# JANELAS DE ENVIO AUTOMATICO (dias antes do vencimento)
# ---------------------------------------------------------------------------

# D-7: aviso antecipado (entre JANELA_D7_MIN e JANELA_D7_MAX dias antes)
JANELA_D7_MIN=5
JANELA_D7_MAX=9

# D-1: lembrete final (entre JANELA_D1_MIN e JANELA_D1_MAX dias antes)
JANELA_D1_MIN=0
JANELA_D1_MAX=4

# Cobranca automatica: dias apos o vencimento
DIAS_APOS_VENC_PARA_COBRAR=2

# ---------------------------------------------------------------------------
# AGENDADOR (formato HH:MM)
# ---------------------------------------------------------------------------

HORA_PIPELINE=08:00
HORA_COBRADOR=09:00
HORA_RESPOSTAS=10:00

# ---------------------------------------------------------------------------
# IA — Anthropic Claude (opcional)
# Deixe vazio para desabilitar classificacao de respostas WhatsApp
# Obtenha em: https://console.anthropic.com/
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=

# Modelo a usar (padrao: claude-haiku-4-5-20251001)
# Atualize aqui quando a Anthropic lancar versoes mais recentes
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# BANCO DE DADOS SQLite (opcional)
# Padrao: consorcio.db na pasta do projeto
# ---------------------------------------------------------------------------

# DB_PATH=C:\ti\Projeto Consorcio\consorcio.db

# ---------------------------------------------------------------------------
# RELATORIO DIARIO POR E-MAIL (opcional)
# Deixe vazio para desabilitar
# Para Gmail: use senha de app em https://myaccount.google.com/apppasswords
# ---------------------------------------------------------------------------

EMAIL_REMETENTE=
EMAIL_SENHA=
EMAIL_DESTINATARIO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
